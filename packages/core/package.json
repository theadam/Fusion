{
  "name": "@fusion/core",
  "version": "0.17.1",
  "license": "MIT",
  "description": "Fusion core: task store, scheduler, settings, and shared domain types backing the Fusion AI coding agent.",
  "homepage": "https://github.com/Runfusion/Fusion#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Runfusion/Fusion",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/Runfusion/Fusion/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./gh-cli": {
      "types": "./src/gh-cli.ts",
      "source": "./src/gh-cli.ts",
      "import": "./dist/gh-cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --silent=passed-only --reporter=dot"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.41",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "private": true,
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "check-disk-space": "^3.4.0",
    "cron-parser": "^5.5.0",
    "dockerode": "^4.0.2",
    "extract-zip": "^2.0.1",
    "tar": "^7.5.13",
    "yaml": "^2.8.3"
  }
}
